[alias]
	s = status -s
	c = clone --recursive
	l = log --pretty=oneline -n 20 --graph --abbrev-commit
	lm = "!git l --author=\"$(git config user.email)\""
	p = "!git pull; git submodule update --recursive"

	d = diff
	ds = diff --staged
	dsum = diff --compact-summary
	dssum = diff --staged --compact-summary

	branches = branch --list --all -vvv
	remotes = remote -v
	contributors = shortlog --summary --numbered

[apply]
	whitespace = fix

[core]
	excludesfile = ~/.gitignore
	attributesfile = ~/.gitattributes
	whitespace = space-before-tab,-indent-with-non-tab,trailing-space
	trustctime = false
	precomposeunicode = false
	autocrlf = input

[gpg]
	program = gpg2

[commit]
	gpgsign = true

[credential]
	helper = cache --timeout=3600

[diff]
	renames = copies

[diff "bin"]
	textconv = hexdump -v -C

[merge]
	log = true

[push]
	default = simple
	followTags = true

[user]
	name = Pascal Mathis
	email = mail@pascalmathis.com
	signingkey = E208DBA7BFC9B28C

[include]
	path = ~/.gitconfig.local
