[bar/main]
monitor = ${env:MONITOR}
width = 100%
height = 35
offset-x = 0
offset-y = 0

spacing = 1
padding-left = 0
padding-right = 0
module-margin-left = 0
module-margin-right = 0

font-0 = Noto Sans:pixelsize=11;0
font-1 = SauceCodePro Nerd Font:size=11;0

modules-left = bspwm xwindow
modules-center =
modules-right = battery date powermenu

foreground = #eeeeeeff
background = #5a000000
underline-size = 2
underline-color = #eeeeeeff

wm-restack = bspwm
scroll-up = bspwm-desknext
scroll-down = bspwm-deskprev

[bar/side]
monitor = ${env:MONITOR}
width = 100%
height = 35
offset-x = 0
offset-y = 0

spacing = 1
padding-left = 0
padding-right = 0
module-margin-left = 0
module-margin-right = 0

font-0 = Noto Sans:pixelsize=11;0
font-1 = SauceCodePro Nerd Font:size=11;0

modules-left = bspwm
modules-center =
modules-right = 

foreground = #eeeeeeff
background = #5a000000
underline-size = 2
underline-color = #eeeeeeff

wm-restack = bspwm
scroll-up = bspwm-desknext
scroll-down = bspwm-deskprev

[module/bspwm]
type = internal/bspwm
format = <label-state> <label-mode>
pin-workspaces = true

label-focused = %name%
label-focused-background = #88000000
label-focused-underline = #ddddddff
label-focused-padding = 4

label-occupied = %name%
label-occupied-padding = 4

label-urgent = %name%
label-urgent-padding = 4

label-empty = %name%
label-empty-foreground = #44ffffff
label-empty-padding = 4

[module/xwindow]
type = internal/xwindow
label = %title:0:120:...%
label-padding = 4

[module/date]
type = internal/date
label = %date% %time%

format =    <label>
format-background = #88000000
format-padding = 3

interval = 1.0
date = %d.%m.%Y
time = %H:%M

[module/battery]
type = internal/battery
poll-interval = 5

battery = BAT0
adapter = ADP1

format-charging = <animation-charging>  <label-charging>
format-discharging = <ramp-capacity>  <label-discharging>
format-full = <ramp-capacity>  <label-full>
label-charging = %percentage%
label-discharging = %percentage%
label-full = %percentage%
format-charging-padding = 3
format-discharging-padding = 3
format-full-padding = 3

ramp-capacity-0 = 
ramp-capacity-1 = 
ramp-capacity-2 = 
ramp-capacity-3 = 
ramp-capacity-4 = 

animation-charging-0 = 
animation-charging-1 = 
animation-charging-2 = 
animation-charging-3 = 
animation-charging-4 = 
animation-charging-framerate = 750

[module/volume]
type = internal/volume

format-volume = <ramp-volume>  <label-volume>
format-muted = <label-muted>
label-volume = %percentage%
label-muted =   muted
label-muted-foreground = #aaa
format-volume-padding = 3
format-muted-padding = 3

ramp-volume-0 = 
ramp-volume-1 = 
ramp-volume-2 = 
ramp-headphones-0 = 

[module/powermenu]
type = custom/menu

label-open =   
label-close = cancel
label-open-padding = 4
label-close-padding = 3

menu-0-0 = reboot
menu-0-0-exec = menu-open-1
menu-0-1 = power off
menu-0-1-exec = menu-open-2
menu-0-0-padding = 3
menu-0-1-padding = 3

menu-1-0 = reboot?  
menu-1-0-exec = systemctl reboot
menu-1-0-padding = 3

menu-2-0 = power off?  
menu-2-0-exec = systemctl poweroff
menu-2-0-padding = 3
